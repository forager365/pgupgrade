//go:embed static/index.html
var staticFiles embed.FS

type App struct {
  sfnClient *sfn.Client
  allowed  map[string]bool

  mu   sync.Mutex
  logs []ActivityLog
}

type StartRequest struct {
  StateMachineArn string         `json:"stateMachineArn"`
  ExecutionName   string         `json:"executionName,omitempty"`
  Input           map[string]any `json:"input"`
}

type StartResponse struct {
  ExecutionArn string `json:"executionArn"`
  StartDate    string `json:"startDate"`
}

type ActivityLog struct {
  Time    string         `json:"time"`
  Level   string         `json:"level"`
  Message string         `json:"message"`
  Fields  map[string]any `json:"fields,omitempty"`
}

func main() {
  ctx := context.Background()

  cfg, err := config.LoadDefaultConfig(ctx)
  if err != nil {
    log.Fatalf("failed to load AWS config: %v", err)
  }

  app := &App{
    sfnClient: sfn.NewFromConfig(cfg),
    allowed:  loadAllowedStateMachines(),
    logs:     make([]ActivityLog, 0, 100),
  }

  if len(app.allowed) == 0 {
    app.addLog("WARN", "No ALLOWED_STATE_MACHINE_ARNS configured; any ARN submitted by the UI will be accepted", nil)
  }

  mux := http.NewServeMux()
  mux.HandleFunc("/", app.handleIndex)
  mux.HandleFunc("GET /api/health", app.handleHealth)
  mux.HandleFunc("GET /api/logs", app.handleLogs)
  mux.HandleFunc("POST /api/start", app.handleStartExecution)

  port := getenv("PORT", "8080")
  addr := ":" + port

  app.addLog("INFO", "Server started", map[string]any{
    "address": addr,
  })

  log.Printf("server listening on http://localhost%s", addr)
  log.Fatal(http.ListenAndServe(addr, mux))
}

func (a *App) handleIndex(w http.ResponseWriter, r *http.Request) {
  if r.URL.Path != "/" {
    http.NotFound(w, r)
    return
  }

  html, err := staticFiles.ReadFile("static/index.html")
  if err != nil {
    http.Error(w, "index.html not found", http.StatusInternalServerError)
    return
  }

  w.Header().Set("Content-Type", "text/html; charset=utf-8")
  _, _ = w.Write(html)
}

func (a *App) handleHealth(w http.ResponseWriter, r *http.Request) {
  writeJSON(w, http.StatusOK, map[string]any{
    "status": "ok",
    "time":   time.Now().Format(time.RFC3339),
  })
}

func (a *App) handleLogs(w http.ResponseWriter, r *http.Request) {
  a.mu.Lock()
  defer a.mu.Unlock()

  copyLogs := make([]ActivityLog, len(a.logs))
  copy(copyLogs, a.logs)

  writeJSON(w, http.StatusOK, copyLogs)
}

func (a *App) handleStartExecution(w http.ResponseWriter, r *http.Request) {
  var req StartRequest

  if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
    a.addLog("ERROR", "Invalid request JSON", map[string]any{
      "error": err.Error(),
    })
    writeError(w, http.StatusBadRequest, "invalid JSON request")
    return
  }

  if strings.TrimSpace(req.StateMachineArn) == "" {
    writeError(w, http.StatusBadRequest, "stateMachineArn is required")
    return
  }

  if !a.isAllowed(req.StateMachineArn) {
    a.addLog("WARN", "Rejected unauthorized state machine ARN", map[string]any{
      "stateMachineArn": req.StateMachineArn,
    })
    writeError(w, http.StatusForbidden, "state machine ARN is not allowed")
    return
  }

  inputBytes, err := json.Marshal(req.Input)
  if err != nil {
    writeError(w, http.StatusBadRequest, "input could not be marshaled as JSON")
    return
  }

  startInput := &sfn.StartExecutionInput{
    StateMachineArn: aws.String(req.StateMachineArn),
    Input:           aws.String(string(inputBytes)),
  }

  if strings.TrimSpace(req.ExecutionName) != "" {
    startInput.Name = aws.String(strings.TrimSpace(req.ExecutionName))
  }

  a.addLog("INFO", "Starting Step Functions execution", map[string]any{
    "stateMachineArn": req.StateMachineArn,
    "input":           string(inputBytes),
  })

  ctx, cancel := context.WithTimeout(r.Context(), 20*time.Second)
  defer cancel()

  out, err := a.sfnClient.StartExecution(ctx, startInput)
  if err != nil {
    a.addLog("ERROR", "Step Functions StartExecution failed", map[string]any{
      "stateMachineArn": req.StateMachineArn,
      "error":           err.Error(),
    })
    writeError(w, http.StatusInternalServerError, fmt.Sprintf("StartExecution failed: %v", err))
    return
  }

  startDate := ""
  if out.StartDate != nil {
    startDate = out.StartDate.Format(time.RFC3339)
  }

  resp := StartResponse{
    ExecutionArn: aws.ToString(out.ExecutionArn),
    StartDate:    startDate,
  }

  a.addLog("INFO", "Step Functions execution started", map[string]any{
    "executionArn": resp.ExecutionArn,
    "startDate":    resp.StartDate,
  })

  writeJSON(w, http.StatusOK, resp)
}

func (a *App) isAllowed(arn string) bool {
  if len(a.allowed) == 0 {
    return true
  }
  return a.allowed[arn]
}

func (a *App) addLog(level, message string, fields map[string]any) {
  a.mu.Lock()
  defer a.mu.Unlock()

  a.logs = append(a.logs, ActivityLog{
    Time:    time.Now().Format(time.RFC3339),
    Level:   level,
    Message: message,
    Fields:  fields,
  })

  if len(a.logs) > 200 {
    a.logs = a.logs[len(a.logs)-200:]
  }
}

func loadAllowedStateMachines() map[string]bool {
  raw := strings.TrimSpace(os.Getenv("ALLOWED_STATE_MACHINE_ARNS"))
  allowed := make(map[string]bool)

  if raw == "" {
    return allowed
  }

  for _, arn := range strings.Split(raw, ",") {
    arn = strings.TrimSpace(arn)
    if arn != "" {
      allowed[arn] = true
    }
  }

  return allowed
}

func writeJSON(w http.ResponseWriter, status int, v any) {
  w.Header().Set("Content-Type", "application/json")
  w.WriteHeader(status)
  _ = json.NewEncoder(w).Encode(v)
}

func writeError(w http.ResponseWriter, status int, message string) {
  writeJSON(w, status, map[string]any{
    "error": message,
  })
}

func getenv(key, fallback string) string {
  val := strings.TrimSpace(os.Getenv(key))
  if val == "" {
    return fallback
  }
  return val
}


