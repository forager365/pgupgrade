<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>AWS Workflow Launcher</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <style>
    body {
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      margin: 0;
      background: #f5f5f5;
      color: #222;
    }

    header {
      background: #232f3e;
      color: white;
      padding: 1rem 2rem;
    }

    main {
      max-width: 1100px;
      margin: 2rem auto;
      padding: 0 1rem;
      display: grid;
      gap: 1.5rem;
    }

    section {
      background: white;
      border: 1px solid #ddd;
      border-radius: 10px;
      padding: 1.25rem;
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }

    label {
      display: block;
      font-weight: 600;
      margin-top: 1rem;
      margin-bottom: 0.35rem;
    }

    input, select {
      width: 100%;
      box-sizing: border-box;
      padding: 0.6rem;
      border: 1px solid #bbb;
      border-radius: 6px;
      font-size: 1rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }

    th, td {
      border-bottom: 1px solid #ddd;
      padding: 0.5rem;
      text-align: left;
      vertical-align: top;
    }

    button {
      cursor: pointer;
      border: 0;
      border-radius: 6px;
      padding: 0.7rem 1rem;
      font-weight: 600;
      background: #ff9900;
      color: #111;
    }

    button.secondary {
      background: #e9e9e9;
    }

    button.danger {
      background: #cc3333;
      color: white;
    }

    .actions {
      display: flex;
      gap: 0.75rem;
      margin-top: 1rem;
      flex-wrap: wrap;
    }

    pre {
      background: #111;
      color: #eee;
      padding: 1rem;
      border-radius: 8px;
      overflow: auto;
      min-height: 80px;
    }

    .log-entry {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      border-bottom: 1px solid #eee;
      padding: 0.5rem 0;
      white-space: pre-wrap;
    }

    .INFO { color: #0b5; }
    .WARN { color: #b87300; }
    .ERROR { color: #c33; }

    .hidden {
      display: none;
    }
  </style>
</head>

<body>
<header>
  <h1>AWS Workflow Launcher</h1>
</header>

<main>
  <section>
    <h2>Launch AWS target</h2>

    <form id="launchForm">
      <label for="targetType">Target Type</label>
      <select id="targetType">
        <option value="sfn">Step Functions</option>
        <option value="lambda">Lambda</option>
      </select>

      <div id="sfnFields">
        <label for="stateMachineArn">State Machine ARN</label>
        <input
          id="stateMachineArn"
          placeholder="arn:aws:states:us-east-1:123456789012:stateMachine:my-state-machine"
        />

        <label for="executionName">Execution Name Optional</label>
        <input
          id="executionName"
          placeholder="my-execution-name"
        />
      </div>

      <div id="lambdaFields" class="hidden">
        <label for="functionName">Lambda Function Name or ARN</label>
        <input
          id="functionName"
          placeholder="my-function or arn:aws:lambda:us-east-1:123456789012:function:my-function"
        />

        <label for="qualifier">Qualifier Optional</label>
        <input
          id="qualifier"
          placeholder="alias or version, for example prod or 3"
        />

        <label for="invocationType">Invocation Type</label>
        <select id="invocationType">
          <option value="RequestResponse">RequestResponse synchronous</option>
          <option value="Event">Event asynchronous</option>
          <option value="DryRun">DryRun permission check</option>
        </select>

        <label>
          <input id="logTail" type="checkbox" style="width:auto" checked />
          Include Lambda log tail for synchronous invocation
        </label>
      </div>

      <h3>JSON Input / Payload</h3>
      <p>
        Use simple keys like <code>env</code>, or dotted keys like
        <code>request.id</code> for nested JSON.
      </p>

      <table>
        <thead>
          <tr>
            <th style="width: 30%">Key</th>
            <th style="width: 20%">Type</th>
            <th>Value</th>
            <th style="width: 90px">Action</th>
          </tr>
        </thead>
        <tbody id="kvRows"></tbody>
      </table>

      <div class="actions">
        <button type="button" class="secondary" onclick="addRow()">Add key</button>
        <button type="submit">Launch</button>
      </div>
    </form>
  </section>

  <section>
    <h2>Generated JSON Preview</h2>
    <pre id="jsonPreview">{}</pre>
  </section>

  <section>
    <h2>Last Response</h2>
    <pre id="responseOutput">No request submitted yet.</pre>
  </section>

  <section>
    <h2>Activity Log</h2>
    <div id="activityLog"></div>
  </section>
</main>

<script>
  const kvRows = document.getElementById("kvRows");
  const jsonPreview = document.getElementById("jsonPreview");
  const responseOutput = document.getElementById("responseOutput");
  const activityLog = document.getElementById("activityLog");

  const targetType = document.getElementById("targetType");
  const sfnFields = document.getElementById("sfnFields");
  const lambdaFields = document.getElementById("lambdaFields");

  targetType.addEventListener("change", () => {
    const isLambda = targetType.value === "lambda";
    sfnFields.classList.toggle("hidden", isLambda);
    lambdaFields.classList.toggle("hidden", !isLambda);
  });

  function addRow(key = "", type = "string", value = "") {
    const tr = document.createElement("tr");

    tr.innerHTML = `
      <td><input class="kv-key" placeholder="request.id" value="${escapeHtml(key)}" /></td>
      <td>
        <select class="kv-type">
          <option value="string">string</option>
          <option value="number">number</option>
          <option value="boolean">boolean</option>
          <option value="json">json</option>
          <option value="null">null</option>
        </select>
      </td>
      <td><input class="kv-value" placeholder="value" value="${escapeHtml(value)}" /></td>
      <td><button type="button" class="danger" onclick="this.closest('tr').remove(); updatePreview();">Remove</button></td>
    `;

    tr.querySelector(".kv-type").value = type;

    tr.querySelectorAll("input, select").forEach(el => {
      el.addEventListener("input", updatePreview);
      el.addEventListener("change", updatePreview);
    });

    kvRows.appendChild(tr);
    updatePreview();
  }

  function buildInputObject() {
    const obj = {};
    const rows = kvRows.querySelectorAll("tr");

    rows.forEach(row => {
      const key = row.querySelector(".kv-key").value.trim();
      const type = row.querySelector(".kv-type").value;
      const rawValue = row.querySelector(".kv-value").value;

      if (!key) {
        return;
      }

      const value = convertValue(type, rawValue);
      setByDottedPath(obj, key, value);
    });

    return obj;
  }

  function convertValue(type, rawValue) {
    switch (type) {
      case "string":
        return rawValue;

      case "number": {
        const n = Number(rawValue);
        if (Number.isNaN(n)) {
          throw new Error(`Invalid number: ${rawValue}`);
        }
        return n;
      }

      case "boolean": {
        const normalized = rawValue.trim().toLowerCase();
        if (["true", "yes", "1"].includes(normalized)) return true;
        if (["false", "no", "0"].includes(normalized)) return false;
        throw new Error(`Invalid boolean: ${rawValue}`);
      }

      case "json":
        return JSON.parse(rawValue);

      case "null":
        return null;

      default:
        return rawValue;
    }
  }

  function setByDottedPath(obj, path, value) {
    const parts = path.split(".").map(p => p.trim()).filter(Boolean);
    let current = obj;

    for (let i = 0; i < parts.length; i++) {
      const part = parts[i];

      if (i === parts.length - 1) {
        current[part] = value;
      } else {
        if (
          typeof current[part] !== "object" ||
          current[part] === null ||
          Array.isArray(current[part])
        ) {
          current[part] = {};
        }
        current = current[part];
      }
    }
  }

  function updatePreview() {
    try {
      const input = buildInputObject();
      jsonPreview.textContent = JSON.stringify(input, null, 2);
    } catch (err) {
      jsonPreview.textContent = "Invalid input: " + err.message;
    }
  }

  document.getElementById("launchForm").addEventListener("submit", async event => {
    event.preventDefault();

    try {
      let endpoint;
      let payload;

      const inputObject = buildInputObject();

      if (targetType.value === "sfn") {
        endpoint = "/api/sfn/start";

        payload = {
          stateMachineArn: document.getElementById("stateMachineArn").value.trim(),
          executionName: document.getElementById("executionName").value.trim(),
          input: inputObject
        };

        appendLocalLog("INFO", "Submitting Step Functions execution request");
      } else {
        endpoint = "/api/lambda/invoke";

        payload = {
          functionName: document.getElementById("functionName").value.trim(),
          qualifier: document.getElementById("qualifier").value.trim(),
          invocationType: document.getElementById("invocationType").value,
          logTail: document.getElementById("logTail").checked,
          payload: inputObject
        };

        appendLocalLog("INFO", "Submitting Lambda invocation request");
      }

      const res = await fetch(endpoint, {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify(payload)
      });

      const body = await res.json();

      if (!res.ok) {
        throw new Error(body.error || "request failed");
      }

      responseOutput.textContent = JSON.stringify(body, null, 2);
      appendLocalLog("INFO", "AWS request completed");
      await refreshLogs();

    } catch (err) {
      responseOutput.textContent = "Error: " + err.message;
      appendLocalLog("ERROR", err.message);
    }
  });

  async function refreshLogs() {
    try {
      const res = await fetch("/api/logs");
      const logs = await res.json();

      activityLog.innerHTML = "";

      logs.slice().reverse().forEach(log => {
        const div = document.createElement("div");
        div.className = "log-entry " + log.level;

        let line = `[${log.time}] ${log.level} ${log.message}`;
        if (log.fields) {
          line += "\n" + JSON.stringify(log.fields, null, 2);
        }

        div.textContent = line;
        activityLog.appendChild(div);
      });
    } catch (err) {
      appendLocalLog("ERROR", "Could not refresh server logs: " + err.message);
    }
  }

  function appendLocalLog(level, message) {
    const div = document.createElement("div");
    div.className = "log-entry " + level;
    div.textContent = `[${new Date().toISOString()}] ${level} ${message}`;
    activityLog.prepend(div);
  }

  function escapeHtml(value) {
    return String(value)
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;");
  }

  addRow("env", "string", "dev");
  addRow("dryRun", "boolean", "true");
  addRow("request.id", "string", "REQ-001");

  setInterval(refreshLogs, 3000);
  refreshLogs();
</script>
</body>
</html>

