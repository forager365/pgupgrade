func (a *App) handleInvokeLambda(w http.ResponseWriter, r *http.Request) {
  var req LambdaInvokeRequest

  if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
    a.addLog("ERROR", "Invalid Lambda request JSON", map[string]any{
      "error": err.Error(),
    })
    writeError(w, http.StatusBadRequest, "invalid JSON request")
    return
  }

  req.FunctionName = strings.TrimSpace(req.FunctionName)

  if req.FunctionName == "" {
    writeError(w, http.StatusBadRequest, "functionName is required")
    return
  }

  if !a.isAllowed(a.allowedLambdas, req.FunctionName) {
    a.addLog("WARN", "Rejected unauthorized Lambda function", map[string]any{
      "functionName": req.FunctionName,
    })
    writeError(w, http.StatusForbidden, "Lambda function is not allowed")
    return
  }

  invocationType, err := parseInvocationType(req.InvocationType)
  if err != nil {
    writeError(w, http.StatusBadRequest, err.Error())
    return
  }

  payloadBytes, err := json.Marshal(req.Payload)
  if err != nil {
    writeError(w, http.StatusBadRequest, "payload could not be marshaled as JSON")
    return
  }

  invokeInput := &awslambda.InvokeInput{
    FunctionName:   aws.String(req.FunctionName),
    InvocationType: invocationType,
    Payload:        payloadBytes,
  }

  if strings.TrimSpace(req.Qualifier) != "" {
    invokeInput.Qualifier = aws.String(strings.TrimSpace(req.Qualifier))
  }

  if req.LogTail && invocationType == lambdatypes.InvocationTypeRequestResponse {
    invokeInput.LogType = lambdatypes.LogTypeTail
  }

  a.addLog("INFO", "Invoking Lambda function", map[string]any{
    "functionName":   req.FunctionName,
    "qualifier":      req.Qualifier,
    "invocationType": string(invocationType),
    "payload":        string(payloadBytes),
  })

  ctx, cancel := context.WithTimeout(r.Context(), 30*time.Second)
  defer cancel()

  out, err := a.lambdaClient.Invoke(ctx, invokeInput)
  if err != nil {
    a.addLog("ERROR", "Lambda Invoke failed", map[string]any{
      "functionName": req.FunctionName,
      "error":        err.Error(),
    })
    writeError(w, http.StatusInternalServerError, fmt.Sprintf("Lambda Invoke failed: %v", err))
    return
  }

  resp := LambdaInvokeResponse{
    StatusCode:      out.StatusCode,
    FunctionError:  aws.ToString(out.FunctionError),
    ExecutedVersion: aws.ToString(out.ExecutedVersion),
    Payload:         string(out.Payload),
  }

  if out.LogResult != nil && aws.ToString(out.LogResult) != "" {
    decoded, err := base64.StdEncoding.DecodeString(aws.ToString(out.LogResult))
    if err == nil {
      resp.LogTail = string(decoded)
    } else {
      resp.LogTail = aws.ToString(out.LogResult)
    }
  }

  fields := map[string]any{
    "functionName":   req.FunctionName,
    "invocationType": string(invocationType),
    "statusCode":     resp.StatusCode,
  }

  if resp.FunctionError != "" {
    fields["functionError"] = resp.FunctionError
  }

  a.addLog("INFO", "Lambda invocation completed", fields)

  writeJSON(w, http.StatusOK, resp)
}

func parseInvocationType(value string) (lambdatypes.InvocationType, error) {
  switch strings.TrimSpace(value) {
  case "", "RequestResponse":
    return lambdatypes.InvocationTypeRequestResponse, nil
  case "Event":
    return lambdatypes.InvocationTypeEvent, nil
  case "DryRun":
    return lambdatypes.InvocationTypeDryRun, nil
  default:
    return "", fmt.Errorf("invalid invocationType: must be RequestResponse, Event, or DryRun")
  }
}

func (a *App) isAllowed(allowed map[string]bool, value string) bool {
  if len(allowed) == 0 {
    return true
  }
  return allowed[value]
}

func (a *App) addLog(level, message string, fields map[string]any) {
  a.mu.Lock()
  defer a.mu.Unlock()

  a.logs = append(a.logs, ActivityLog{
    Time:    time.Now().Format(time.RFC3339),
    Level:   level,
    Message: message,
    Fields:  fields,
  })

  if len(a.logs) > 200 {
    a.logs = a.logs[len(a.logs)-200:]
  }
}

func loadAllowedList(envName string) map[string]bool {
  raw := strings.TrimSpace(os.Getenv(envName))
  allowed := make(map[string]bool)

  if raw == "" {
    return allowed
  }

  for _, item := range strings.Split(raw, ",") {
    item = strings.TrimSpace(item)
    if item != "" {
      allowed[item] = true
    }
  }

  return allowed
}

func writeJSON(w http.ResponseWriter, status int, v any) {
  w.Header().Set("Content-Type", "application/json")
  w.WriteHeader(status)
  _ = json.NewEncoder(w).Encode(v)
}

func writeError(w http.ResponseWriter, status int, message string) {
  writeJSON(w, status, map[string]any{
    "error": message,
  })
}

func getenv(key, fallback string) string {
  val := strings.TrimSpace(os.Getenv(key))
  if val == "" {
    return fallback
  }
  return val
}
