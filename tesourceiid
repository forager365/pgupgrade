# CLI
# --------------------------------------------------------------------------- #

def parse_args(argv: list[str]) -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="Audit IAM and resource policies for RDS resource ID references",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    p.add_argument("--identifier", required=True,
                   help="RDS DB instance or cluster identifier")
    p.add_argument("--region", required=True, help="AWS region")
    p.add_argument("--profile", help="AWS named profile")
    p.add_argument("--check-cross-account", nargs="*", metavar="ACCOUNT_ID",
                   help="Cross-account IDs to scan (assumes "
                        "RDSResourceIdAuditRole exists in each)")
    return p.parse_args(argv)


def main() -> int:
    args = parse_args(sys.argv[1:])
    try:
        return run(args)
    except KeyboardInterrupt:
        log.error("Interrupted")
        return 130
    except SystemExit as e:
        if isinstance(e.code, str):
            log.error(e.code)
            return 1
        return int(e.code or 0)


if __name__ == "__main__":
    sys.exit(main())


