package main

import (
  "context"
  "encoding/json"
  "fmt"
  "html/template"
  "log"
  "net/http"
  "time"

  "github.com/aws/aws-sdk-go-v2/aws"
  "github.com/aws/aws-sdk-go-v2/config"
  "github.com/aws/aws-sdk-go-v2/service/lambda"
  "github.com/aws/aws-sdk-go-v2/service/lambda/types"
)

// Global Lambda client wrapper
type LambdaClient struct {
  Client *lambda.Client
}

// Struct to parse incoming invocation requests from the UI
type InvokeRequest struct {
  FunctionName string            `json:"functionName"`
  PayloadData  map[string]string `json:"payloadData"`
}

func main() {
  // Initialize AWS Config (Loads from ~/.aws/credentials, config, or IAM Roles)
  cfg, err := config.LoadDefaultConfig(context.TODO())
  if err != nil {
    log.Fatalf("unable to load SDK config, %v", err)
  }

  awsClient := &LambdaClient{
    Client: lambda.NewFromConfig(cfg),
  }

  // Route Handlers
  http.HandleFunc("/", handleHome)
  http.HandleFunc("/api/functions", awsClient.handleListFunctions)
  http.HandleFunc("/api/invoke", awsClient.handleInvoke)

  serverAddr := ":8080"
  fmt.Printf("🚀 Server started at http://localhost%s\n", serverAddr)
  if err := http.ListenAndServe(serverAddr, nil); err != nil {
    log.Fatalf("Server failed to start: %v", err)
  }
}

// Serves the single-page frontend application
func handleHome(w http.ResponseWriter, r *http.Request) {
  tmpl := template.Must(template.New("index").Parse(htmlTemplate))
  tmpl.Execute(w, nil)
}

// API: Lists the available Lambda functions in the configured region
func (lc *LambdaClient) handleListFunctions(w http.ResponseWriter, r *http.Request) {
  w.Header().Set("Content-Type", "application/json")
  
  paginator := lambda.NewListFunctionsPaginator(lc.Client, &lambda.ListFunctionsInput{})
  var functions []string

  for paginator.HasMorePages() {
    page, err := paginator.NextPage(context.TODO())
    if err != nil {
      http.Error(w, fmt.Sprintf(`{"error": "%s"}`, err.Error()), http.StatusInternalServerError)
      return
    }
    for _, f := range page.Functions {
      functions = append(functions, *f.FunctionName)
    }
  }

  json.NewEncoder(w).Encode(functions)
}

// API: Converts form key-values to JSON, invokes the Lambda, and extracts logs
func (lc *LambdaClient) handleInvoke(w http.ResponseWriter, r *http.Request) {
  w.Header().Set("Content-Type", "application/json")
  if r.Method != http.MethodPost {
    http.Error(w, `{"error": "Method not allowed"}`, http.StatusMethodNotAllowed)
    return
  }

  var req InvokeRequest
  if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
    http.Error(w, `{"error": "Invalid request body"}`, http.StatusBadRequest)
    return
  }

  // Convert map[string]string payload to pure JSON bytes
  payloadBytes, err := json.Marshal(req.PayloadData)
  if err != nil {
    http.Error(w, `{"error": "Failed to process JSON payload"}`, http.StatusInternalServerError)
    return
  }

  startTime := time.Now()

  // Invoke the Lambda Function
  input := &lambda.InvokeInput{
    FunctionName:   aws.String(req.FunctionName),
    Payload:        payloadBytes,
    LogType:        types.LogTypeTail, // Requests execution logs to be returned in the response
  }

  output, err := lc.Client.Invoke(context.TODO(), input)
  duration := time.Since(startTime)

  if err != nil {
    http.Error(w, fmt.Sprintf(`{"error": "Lambda execution failed: %s"}`, err.Error()), http.StatusInternalServerError)
    return
  }

  // Prepare standard execution metrics alongside AWS metadata payload
  responseMap := map[string]interface{}{
    "statusCode":   output.StatusCode,
    "payload":      string(output.Payload),
    "durationMs":   duration.Milliseconds(),
  }

  // If logs exist, they come back base64 encoded inside output.LogResult
  if output.LogResult != nil {
    responseMap["logResult"] = *output.LogResult
  }
  if output.FunctionError != nil {
    responseMap["functionError"] = *output.FunctionError
  }

  json.NewEncoder(w).Encode(responseMap)
}

